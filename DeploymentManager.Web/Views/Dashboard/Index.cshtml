@model IEnumerable<DeploymentManager.Web.Models.Server>
@{
    ViewData["Title"] = "Deploy Dashboard";
    var recentDeployments = ViewBag.RecentDeployments as IEnumerable<DeploymentManager.Web.Models.Deployment> ?? new List<DeploymentManager.Web.Models.Deployment>();
}

<!-- Metrics Section -->
<div class="row g-4 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="stat-card card-glass">
            <div class="stat-icon servers">
                <i class="bi bi-server"></i>
            </div>
            <div>
                <h3 class="fw-bold mb-0 text-white">@ViewBag.TotalServers</h3>
                <small class="text-secondary-light">Total Servers</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card card-glass">
            <div class="stat-icon active">
                <i class="bi bi-hdd-network-fill"></i>
            </div>
            <div>
                <h3 class="fw-bold mb-0 text-white" id="metric-active-servers">@ViewBag.ActiveServers</h3>
                <small class="text-secondary-light">Active Targets</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card card-glass">
            <div class="stat-icon success">
                <i class="bi bi-patch-check-fill"></i>
            </div>
            <div>
                <h3 class="fw-bold mb-0 text-white" id="metric-success">@ViewBag.SuccessDeployments</h3>
                <small class="text-secondary-light">Successful Runs</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card card-glass">
            <div class="stat-icon failed">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div>
                <h3 class="fw-bold mb-0 text-white" id="metric-failed">@ViewBag.FailedDeployments</h3>
                <small class="text-secondary-light">Failed Runs</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Deployment Trigger Form (Left Panel) -->
    <div class="col-lg-5">
        <div class="card card-glass p-4 h-100">
            <h4 class="fw-bold mb-3 text-gradient"><i class="bi bi-send-fill me-2"></i>Trigger Deployment</h4>
            <p class="text-secondary-light fs-7 mb-4">Select target servers and provide release metadata to deploy the package in parallel across environments.</p>
            
            <form id="deployForm">
                <!-- Server Selector List -->
                <div class="mb-4">
                    <label class="form-label d-flex justify-content-between">
                        <span>Select Target Servers</span>
                        <a href="javascript:void(0);" id="selectAllServers" class="text-primary text-decoration-none fs-7 fw-semibold">Select All</a>
                    </label>
                    
                    @if (!Model.Any())
                    {
                        <div class="text-center py-4 border border-secondary border-opacity-10 rounded bg-black bg-opacity-20">
                            <i class="bi bi-hdd-stack-fill text-muted fs-2"></i>
                            <p class="text-secondary-light mb-0 mt-2">No servers registered yet.</p>
                            <a asp-controller="Servers" asp-action="Create" class="btn btn-sm btn-primary-gradient mt-2">Add First Server</a>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-2" style="max-height: 250px; overflow-y: auto; padding-right: 4px;">
                            @foreach (var server in Model)
                            {
                                <div class="form-check p-0">
                                    <input type="checkbox" name="serverIds" value="@server.Id" id="srv-@server.Id" class="server-checkbox-input d-none" />
                                    <label class="server-checkbox-label w-100" for="srv-@server.Id">
                                        <div class="server-checkbox-card p-3 d-flex align-items-center justify-content-between">
                                            <div class="d-flex align-items-center gap-3">
                                                <i class="bi bi-hdd-fill text-secondary"></i>
                                                <div>
                                                    <div class="fw-semibold text-white fs-6">@server.Name</div>
                                                    <span class="fs-7 text-secondary-light">@server.IpAddress @(!string.IsNullOrEmpty(server.Domain) ? $"({server.Domain})" : "")</span>
                                                </div>
                                            </div>
                                            <span class="badge @(server.Status == "Active" ? "badge-success-glow" : "badge-danger-glow") px-2 py-1 fs-8">
                                                @server.Status
                                            </span>
                                        </div>
                                    </label>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Version -->
                <div class="mb-3">
                    <label for="version" class="form-label">Deployment Version</label>
                    <input type="text" class="form-control" id="version" name="version" placeholder="e.g. 1.0.0" value="1.0.0" required />
                </div>

                <!-- Package URL -->
                <div class="mb-4">
                    <label for="packageUrl" class="form-label">Package URL (.zip)</label>
                    <input type="url" class="form-control" id="packageUrl" name="packageUrl" 
                           placeholder="https://storage/releases/1.0.0.zip" 
                           value="https://raw.githubusercontent.com/username/repository/main/releases/sample-release.zip" required />
                    <span class="fs-8 text-secondary-light mt-1 d-block">Zip package must contain website deployment files in its root structure.</span>
                </div>

                <!-- Submit Button -->
                <button type="button" id="btnDeploy" class="btn btn-primary-gradient w-100 py-3 mt-2" @(Model.Any() ? "" : "disabled")>
                    <i class="bi bi-rocket-takeoff-fill me-2 fs-5"></i> Execute Parallel Deployment
                </button>
            </form>
        </div>
    </div>

    <!-- Active Stream Console (Right Panel) -->
    <div class="col-lg-7">
        <div class="card card-glass p-4 h-100 d-flex flex-column">
            <h4 class="fw-bold mb-3 text-gradient"><i class="bi bi-terminal-fill me-2"></i>Deployment Console</h4>
            <p class="text-secondary-light fs-7 mb-4">Click "View Logs" on an active target or select a history record to stream real-time logs directly from the server agent.</p>
            
            <!-- Active Deploying Servers Table -->
            <div id="activeRunPanel" class="mb-4 d-none">
                <h6 class="fw-bold text-white mb-2">Active Execution Status</h6>
                <div class="table-responsive">
                    <table class="table table-dark-custom align-middle">
                        <thead>
                            <tr>
                                <th>Target Server</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="activeRunTableBody">
                            <!-- Populated dynamically via AJAX -->
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Terminal Container -->
            <div class="flex-grow-1 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-secondary-light fs-7 fw-semibold" id="consoleHeader">CONSOLE: Idle</span>
                    <button id="btnClearConsole" class="btn btn-sm btn-outline-secondary py-1 px-2 text-secondary-light border-secondary border-opacity-25 fs-8">
                        <i class="bi bi-trash-fill"></i> Clear Console
                    </button>
                </div>
                <div class="terminal-console flex-grow-1" id="terminalConsole">
                    <div class="terminal-line manager"><span class="terminal-timestamp">[System]</span>Waiting to trigger or view logs...</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- History Log Section -->
<div class="row mt-4">
    <div class="col-100">
        <div class="card card-glass p-4">
            <h4 class="fw-bold mb-3 text-gradient"><i class="bi bi-clock-history me-2"></i>Deployment History</h4>
            <div class="table-responsive">
                <table class="table table-dark-custom align-middle">
                    <thead>
                        <tr>
                            <th>Server</th>
                            <th>Version</th>
                            <th>Package Link</th>
                            <th>Started At</th>
                            <th>Status</th>
                            <th class="text-end">Logs</th>
                        </tr>
                    </thead>
                    <tbody id="historyTableBody">
                        @if (!recentDeployments.Any())
                        {
                            <tr id="noHistoryRow">
                                <td colspan="6" class="text-center py-4 text-secondary-light">
                                    No deployments have been executed yet.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var dep in recentDeployments)
                            {
                                <tr>
                                    <td class="fw-semibold text-white">@(dep.Server?.Name ?? "Unknown Server")</td>
                                    <td><span class="badge bg-secondary text-light px-2 py-1 fs-8">v@(dep.Version)</span></td>
                                    <td class="text-truncate" style="max-width: 250px;"><a href="@dep.PackageUrl" target="_blank" class="text-info text-decoration-none fs-7">@dep.PackageUrl</a></td>
                                    <td class="text-secondary-light fs-7">@dep.StartedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>
                                        @if (dep.Status == "Success")
                                        {
                                            <span class="badge badge-success-glow px-2 py-1 fs-8">Success</span>
                                        }
                                        else if (dep.Status == "Failed")
                                        {
                                            <span class="badge badge-danger-glow px-2 py-1 fs-8">Failed</span>
                                        }
                                        else if (dep.Status == "InProgress")
                                        {
                                            <span class="badge badge-info-glow px-2 py-1 fs-8">
                                                <span class="status-pulse-inprogress me-1"></span> In Progress
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning-glow px-2 py-1 fs-8">@dep.Status</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary py-1 px-3 fs-8 load-history-log" data-id="@dep.Id" data-name="@(dep.Server?.Name)">
                                            <i class="bi bi-eye-fill"></i> View Logs
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function() {
        let activeDeployments = {}; // key: deploymentId, value: { serverName, status }
        let selectedDeploymentIdForConsole = null;

        // Start SignalR Connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/deploymentHub")
            .withAutomaticReconnect()
            .build();

        connection.start()
            .then(() => console.log("SignalR Connected to Hub"))
            .catch(err => console.error("SignalR Connection Error: ", err));

        // SignalR Log Received Handler
        connection.on("ReceiveLog", function(log) {
            // Only output to console if we currently select this deployment
            if (selectedDeploymentIdForConsole === log.deploymentId || (log.deploymentId === undefined)) {
                appendLogLine(log.message, log.timestamp, log.isError);
            }
        });

        // SignalR Deployment Status Updated Handler
        connection.on("UpdateDeploymentStatus", function(data) {
            // Update status in active grid
            const statusCell = $(`#status-badge-${data.deploymentId}`);
            if (statusCell.length > 0) {
                let badgeClass = "badge-warning-glow";
                let badgeHtml = data.status;

                if (data.status === "Success") {
                    badgeClass = "badge-success-glow";
                    updateMetric("metric-success", 1);
                } else if (data.status === "Failed") {
                    badgeClass = "badge-danger-glow";
                    updateMetric("metric-failed", 1);
                } else if (data.status === "InProgress") {
                    badgeClass = "badge-info-glow";
                    badgeHtml = `<span class="status-pulse-inprogress me-1"></span> In Progress`;
                }

                statusCell.removeClass("badge-warning-glow badge-success-glow badge-danger-glow badge-info-glow")
                          .addClass(badgeClass)
                          .html(badgeHtml);
            }

            // If it completed, let's remove from active list if all done, or simply allow loading logs
            if (data.status === "Success" || data.status === "Failed") {
                // If it is the selected deployment, log manager finish
                if (selectedDeploymentIdForConsole === data.deploymentId) {
                    appendLogLine(`[Manager] Finished deployment execution: ${data.status}`, new Date().toISOString(), data.status === "Failed");
                }
            }
        });

        // Select All Servers
        $("#selectAllServers").click(function() {
            const allChecked = $(".server-checkbox-input:checked").length === $(".server-checkbox-input").length;
            $(".server-checkbox-input").prop("checked", !allChecked);
        });

        // Trigger Deploy Action
        $("#btnDeploy").click(function() {
            const serverIds = [];
            $(".server-checkbox-input:checked").each(function() {
                serverIds.push($(this).val());
            });

            if (serverIds.length === 0) {
                alert("Please select at least one server target!");
                return;
            }

            const version = $("#version").val().trim();
            const packageUrl = $("#packageUrl").val().trim();

            if (!version || !packageUrl) {
                alert("Please fill in both Version and Package URL!");
                return;
            }

            // Disable button during initialization
            $("#btnDeploy").prop("disabled", true).html('<span class="spinner-border spinner-border-sm me-2"></span> Dispatching...');

            $.ajax({
                url: '/Dashboard/Deploy',
                type: 'POST',
                data: {
                    serverIds: serverIds,
                    version: version,
                    packageUrl: packageUrl
                },
                success: function(response) {
                    $("#btnDeploy").prop("disabled", false).html('<i class="bi bi-rocket-takeoff-fill me-2 fs-5"></i> Execute Parallel Deployment');
                    
                    if (response.success) {
                        // Display active run panel
                        $("#activeRunPanel").removeClass("d-none");
                        $("#activeRunTableBody").empty();

                        // Add new runs to active list
                        response.deployments.forEach(function(dep, index) {
                            // Join SignalR Hub Group for this deployment
                            connection.invoke("JoinDeploymentGroup", dep.deploymentId)
                                .then(() => console.log(`Joined group for deployment: ${dep.deploymentId}`))
                                .catch(err => console.error(err));

                            // Add table row
                            const row = `
                                <tr>
                                    <td class="fw-semibold text-white">
                                        ${dep.serverName} 
                                        <div class="fs-8 text-secondary-light">v${dep.version}</div>
                                    </td>
                                    <td>
                                        <span id="status-badge-${dep.deploymentId}" class="badge badge-info-glow px-2 py-1 fs-8">
                                            <span class="status-pulse-inprogress me-1"></span> In Progress
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-primary-gradient py-1 px-3 fs-8 view-console-btn" data-id="${dep.deploymentId}" data-name="${dep.serverName}">
                                            <i class="bi bi-terminal"></i> View Logs
                                        </button>
                                    </td>
                                </tr>
                            `;
                            $("#activeRunTableBody").append(row);

                            // Auto select the first deployment for the log console
                            if (index === 0) {
                                selectDeploymentForConsole(dep.deploymentId, dep.serverName);
                            }
                        });

                        // Add to history table dynamically
                        $("#noHistoryRow").remove();
                        response.deployments.forEach(function(dep) {
                            const histRow = `
                                <tr class="bg-primary bg-opacity-10">
                                    <td class="fw-semibold text-white">${dep.serverName}</td>
                                    <td><span class="badge bg-secondary text-light px-2 py-1 fs-8">v${dep.version}</span></td>
                                    <td class="text-truncate text-secondary" style="max-width: 250px;"><a href="${packageUrl}" target="_blank" class="text-info text-decoration-none fs-7">${packageUrl}</a></td>
                                    <td class="text-secondary-light fs-7">${dep.startedAt}</td>
                                    <td><span id="status-badge-${dep.deploymentId}" class="badge badge-info-glow px-2 py-1 fs-8">In Progress</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary py-1 px-3 fs-8 load-history-log" data-id="${dep.deploymentId}" data-name="${dep.serverName}">
                                            <i class="bi bi-eye-fill"></i> View Logs
                                        </button>
                                    </td>
                                </tr>
                            `;
                            $("#historyTableBody").prepend(histRow);
                        });
                    } else {
                        alert("Error starting deployment: " + response.message);
                    }
                },
                error: function(err) {
                    $("#btnDeploy").prop("disabled", false).html('<i class="bi bi-rocket-takeoff-fill me-2 fs-5"></i> Execute Parallel Deployment');
                    alert("System error sending request.");
                }
            });
        });

        // Click View Logs on Active Target
        $(document).on("click", ".view-console-btn", function() {
            const id = $(this).data("id");
            const name = $(this).data("name");
            selectDeploymentForConsole(id, name);
        });

        // Click View Logs on History List
        $(document).on("click", ".load-history-log", function() {
            const id = $(this).data("id");
            const name = $(this).data("name");
            selectDeploymentForConsole(id, name, true); // Load existing database logs
        });

        // Clear Console
        $("#btnClearConsole").click(function() {
            $("#terminalConsole").empty();
        });

        function selectDeploymentForConsole(deploymentId, serverName, fetchFromDb = false) {
            selectedDeploymentIdForConsole = deploymentId;
            $("#consoleHeader").text(`CONSOLE: Streaming [${serverName}]`);
            $("#terminalConsole").empty().append(`<div class="terminal-line manager"><span class="terminal-timestamp">[System]</span>Subscribed to logs for server [${serverName}]...</div>`);

            // If history load, fetch all lines from DB
            if (fetchFromDb) {
                $("#consoleHeader").text(`CONSOLE: History logs [${serverName}]`);
                $.getJSON(`/Dashboard/GetDeploymentLogs/${deploymentId}`, function(logs) {
                    if (logs.length === 0) {
                        $("#terminalConsole").append(`<div class="terminal-line warning"><span class="terminal-timestamp">[System]</span>No logs found for this run.</div>`);
                    } else {
                        logs.forEach(function(log) {
                            appendLogLine(log.message, log.timestamp, log.isError);
                        });
                    }
                });
            }
        }

        function appendLogLine(message, timestamp, isError) {
            const timeFormatted = timestamp ? timestamp.split(" ").pop() : new Date().toLocaleTimeString();
            let logClass = "";
            if (isError) logClass = "error";
            else if (message.includes("[IIS Simulation]") || message.includes("[IIS]")) logClass = "warning";
            else if (message.includes("[Manager]")) logClass = "manager";

            const logElement = $(`
                <div class="terminal-line ${logClass}">
                    <span class="terminal-timestamp">[${timeFormatted}]</span>${escapeHtml(message)}
                </div>
            `);
            $("#terminalConsole").append(logElement);
            
            // Auto scroll console to bottom
            const consoleElement = document.getElementById("terminalConsole");
            consoleElement.scrollTop = consoleElement.scrollHeight;
        }

        function updateMetric(elementId, increment) {
            const element = $(`#${elementId}`);
            if (element.length > 0) {
                const currentVal = parseInt(element.text()) || 0;
                element.text(currentVal + increment);
            }
        }

        function escapeHtml(text) {
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }
    });
</script>
}
