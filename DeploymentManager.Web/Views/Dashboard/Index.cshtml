@model IEnumerable<DeploymentManager.Web.Models.Server>
@{
    ViewData["Title"] = "لوحة التحكم بالنشر";
    var recentDeployments = ViewBag.RecentDeployments as IEnumerable<DeploymentManager.Web.Models.Deployment> ?? new List<DeploymentManager.Web.Models.Deployment>();
}

@* <!-- قسم المؤشرات والإحصائيات -->
<div class="row g-4 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="stat-card card-glass">
            <div class="stat-icon servers">
                <i class="bi bi-server"></i>
            </div>
            <div>
                <h3 class="fw-bold mb-0 text-white">@ViewBag.TotalServers</h3>
                <small class="text-secondary-light">إجمالي السيرفرات</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card card-glass">
            <div class="stat-icon active">
                <i class="bi bi-hdd-network-fill"></i>
            </div>
            <div>
                <h3 class="fw-bold mb-0 text-white" id="metric-active-servers">@ViewBag.ActiveServers</h3>
                <small class="text-secondary-light">السيرفرات النشطة</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card card-glass">
            <div class="stat-icon success">
                <i class="bi bi-patch-check-fill"></i>
            </div>
            <div>
                <h3 class="fw-bold mb-0 text-white" id="metric-success">@ViewBag.SuccessDeployments</h3>
                <small class="text-secondary-light">العمليات الناجحة</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card card-glass">
            <div class="stat-icon failed">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div>
                <h3 class="fw-bold mb-0 text-white" id="metric-failed">@ViewBag.FailedDeployments</h3>
                <small class="text-secondary-light">العمليات الفاشلة</small>
            </div>
        </div>
    </div>
</div> *@

<!-- قسم السيرفرات المستهدفة بعرض الشاشة -->
<div class="card card-glass p-4 mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h4 class="fw-bold mb-1 text-gradient"><i class="bi bi-hdd-network-fill me-2"></i>السيرفرات المستهدفة</h4>
        </div>
        <div class="d-flex flex-wrap gap-3 align-items-center">
            <div class="position-relative">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-secondary-light"></i>
                <input type="text" id="serverSearch" class="form-control ps-5 bg-dark bg-opacity-50 border-secondary border-opacity-25 text-white" placeholder="ابحث عن سيرفر...">
            </div>
            <a href="javascript:void(0);" id="selectAllServers" class="btn btn-outline-primary btn-sm fw-semibold">تحديد الكل</a>
        </div>
    </div>
    
    <form id="deployForm">
        @if (!Model.Any())
        {
            <div class="text-center py-4 border border-secondary border-opacity-10 rounded bg-black bg-opacity-20">
                <i class="bi bi-hdd-stack-fill text-muted fs-2"></i>
                <p class="text-secondary-light mb-0 mt-2">لا توجد سيرفرات مسجلة حالياً.</p>
                <a asp-controller="Servers" asp-action="Create" class="btn btn-sm btn-primary-gradient mt-2">إضافة أول سيرفر</a>
            </div>
        }
        else
        {
            <div class="row g-3" id="serverGrid" style="max-height: 400px; overflow-y: auto; overflow-x: hidden;">
                @foreach (var server in Model)
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-2 server-option-item" data-search="@server.IisSiteName.ToLower() @server.Name.ToLower() @server.IpAddress.ToLower()">
                        <input type="checkbox" name="serverIds" value="@server.Id" id="srv-@server.Id" class="server-checkbox-input d-none" />
                        <label class="server-checkbox-label w-100 h-100" for="srv-@server.Id">
                            <div class="server-checkbox-card p-3 h-100 d-flex flex-column justify-content-between gap-3">
                                <div class="d-flex align-items-start justify-content-between">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="server-icon-wrapper" style="width: 40px; height: 40px;">
                                            <i class="bi bi-globe"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold text-white fs-6 text-truncate" style="max-width: 100px;" title="@server.IisSiteName">@server.IisSiteName</div>
                                            <span class="fs-7 text-secondary-light text-truncate d-block" style="max-width: 100px;" title="@server.Name - @server.IpAddress">@server.Name</span>
                                        </div>
                                    </div>
                                    <div class="custom-check-indicator flex-shrink-0">
                                        <i class="bi bi-check-lg"></i>
                                    </div>
                                </div>
                                <div class="mt-auto">
                                    <span class="badge @(server.Status == "Active" ? "badge-success-glow" : "badge-danger-glow") px-2 py-1 fs-8">
                                        @(server.Status == "Active" ? "نشط" : "غير نشط")
                                    </span>
                                </div>
                            </div>
                        </label>
                    </div>
                }
            </div>
        }
    </form>
</div>

<div class="row g-4">
    <!-- لوحة بيانات النشر (الجانب الأيمن) -->
    <div class="col-lg-5">
        <div class="card card-glass p-4 h-100 d-flex flex-column">
            <h4 class="fw-bold mb-3 text-gradient"><i class="bi bi-send-fill me-2"></i>بيانات النشر</h4>
            <p class="text-secondary-light fs-7 mb-4">حدد رابط الحزمة البرمجية لبدء النشر على السيرفرات المحددة.</p>
            
            <!-- رابط الحزمة ZIP -->
            <div class="mb-4">
                <label for="packageUrl" class="form-label">رابط حزمة النشر (ZIP URL)</label>
                <input type="url" class="form-control" id="packageUrl" name="packageUrl" 
                       placeholder="https://storage/releases/1.0.0.zip" 
                       value="http://localhost:5026/releases/sample-release.zip" required />
                <span class="fs-8 text-secondary-light mt-1 d-block">يجب أن يحتوي ملف الـ ZIP على ملفات التطبيق التنفيذية في جذره مباشرة.</span>
            </div>

            <!-- زر بدء النشر -->
            <button type="button" id="btnDeploy" class="btn btn-primary-gradient w-100 py-3 mt-auto" @(Model.Any() ? "" : "disabled")>
                <i class="bi bi-rocket-takeoff-fill me-2 fs-5"></i> تنفيذ النشر المتوازي
            </button>
        </div>
    </div>

    <!-- شاشة المراقبة وبث السجلات (الجانب الأيسر) -->
    <div class="col-lg-7">
        <div class="card card-glass p-4 h-100 d-flex flex-column">
            <h4 class="fw-bold mb-3 text-gradient"><i class="bi bi-terminal-fill me-2"></i>شاشة المراقبة وبث السجلات</h4>            
            <!-- جدول السيرفرات التي يجري النشر عليها حالياً -->
            @* <div id="activeRunPanel" class="mb-4 d-none">
                <h6 class="fw-bold text-white mb-2">السيرفرات قيد التشغيل الحالي</h6>
                <div class="table-responsive">
                    <table class="table table-dark-custom align-middle">
                        <thead>
                            <tr>
                                <th>الموقع المستهدف</th>
                                <th>حالة النشر</th>
                                <th class="text-end">السجلات</th>
                            </tr>
                        </thead>
                        <tbody id="activeRunTableBody">
                            <!-- يتم البناء برمجياً بالـ JavaScript -->
                        </tbody>
                    </table>
                </div>
            </div> *@

            <!-- الكونسول البرمجي -->
            <div class="flex-grow-1 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-secondary-light fs-7 fw-semibold" id="consoleHeader">المراقب: خامل</span>
                    <button id="btnClearConsole" class="btn btn-sm btn-outline-secondary py-1 px-2 text-secondary-light border-secondary border-opacity-25 fs-8">
                        <i class="bi bi-trash-fill"></i> مسح الكونسول
                    </button>
                </div>
                <div class="terminal-console flex-grow-1" id="terminalConsole">
                    <div class="terminal-line manager"><span class="terminal-timestamp">[النظام]</span>في انتظار إطلاق عملية نشر أو استدعاء سجلات سابقة...</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- سجل العمليات السابقة -->
<div class="row mt-4">
    <div class="col-120">
        <div class="card card-glass p-4">
            <h4 class="fw-bold mb-3 text-gradient"><i class="bi bi-clock-history me-2"></i>سجل العمليات السابقة</h4>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>الموقع والسيرفر</th>
                            <th>رابط الحزمة</th>
                            <th>وقت البدء</th>
                            <th>الحالة</th>
                            <th class="text-end">السجلات</th>
                        </tr>
                    </thead>
                    <tbody id="historyTableBody">
                        @if (!recentDeployments.Any())
                        {
                            <tr id="noHistoryRow">
                                <td colspan="5" class="text-center py-4 text-secondary-light">
                                    لم يتم تنفيذ أي عملية نشر حتى الآن.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var dep in recentDeployments)
                            {
                                <tr>
                                    <td class="fw-semibold text-white">
                                        <div title="@(dep.Server?.Name)">@(dep.Server?.IisSiteName ?? "موقع غير معروف")</div>
                                        <small class="text-secondary-light">@(dep.Server?.Name ?? "سيرفر غير معروف")</small>
                                    </td>
                                    <td class="text-truncate" style="max-width: 250px;"><a href="@dep.PackageUrl" target="_blank" class="text-info text-decoration-none fs-7">@dep.PackageUrl</a></td>
                                    <td class="text-secondary-light fs-7">@dep.StartedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>
                                        @if (dep.Status == "Success")
                                        {
                                            <span class="badge badge-success-glow px-2 py-1 fs-8 status-badge-@dep.Id">ناجح</span>
                                        }
                                        else if (dep.Status == "Failed")
                                        {
                                            <span class="badge badge-danger-glow px-2 py-1 fs-8 status-badge-@dep.Id">فاشل</span>
                                        }
                                        else if (dep.Status == "InProgress")
                                        {
                                            <span class="badge badge-info-glow px-2 py-1 fs-8 status-badge-@dep.Id">
                                                <span class="status-pulse-inprogress me-1"></span> جاري النشر
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning-glow px-2 py-1 fs-8 status-badge-@dep.Id">@dep.Status</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary py-1 px-3 fs-8 load-history-log" data-id="@dep.Id" data-site="@(dep.Server?.IisSiteName ?? "موقع غير معروف")">
                                            <i class="bi bi-eye-fill"></i> عرض السجلات
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            
            @if (ViewBag.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination justify-content-center" data-bs-theme="dark">
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="?page=@(ViewBag.CurrentPage - 1)">السابق</a>
                        </li>
                        
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                <a class="page-link" href="?page=@i">@i</a>
                            </li>
                        }

                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="?page=@(ViewBag.CurrentPage + 1)">التالي</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function() {
        let activeDeployments = {}; 
        let selectedDeploymentIdForConsole = null;

        // الاتصال بـ SignalR Hub
        let connection = null;
        const signalRAvailable = typeof signalR !== "undefined";
        
        if (signalRAvailable) {
            connection = new signalR.HubConnectionBuilder()
                .withUrl("/deploymentHub")
                .withAutomaticReconnect()
                .build();

            connection.start()
                .then(() => console.log("SignalR Connected to Hub"))
                .catch(err => console.error("SignalR Connection Error: ", err));

            // استقبال السجلات فورا عبر البث الحي
            connection.on("ReceiveLog", function(log) {
                if (selectedDeploymentIdForConsole === log.deploymentId || (log.deploymentId === undefined)) {
                    appendLogLine(log.message, log.timestamp, log.isError);
                }
            });

            // استقبال تحديثات الحالة
            connection.on("UpdateDeploymentStatus", function(data) {
                const statusCell = $(`.status-badge-${data.deploymentId}`);
                if (statusCell.length > 0) {
                    let badgeClass = "badge-warning-glow";
                    let badgeHtml = data.status;

                    if (data.status === "Success") {
                        badgeClass = "badge-success-glow";
                        badgeHtml = "ناجح";
                        updateMetric("metric-success", 1);
                    } else if (data.status === "Failed") {
                        badgeClass = "badge-danger-glow";
                        badgeHtml = "فاشل";
                        updateMetric("metric-failed", 1);
                    } else if (data.status === "InProgress") {
                        badgeClass = "badge-info-glow";
                        badgeHtml = `<span class="status-pulse-inprogress me-1"></span> جاري النشر`;
                    }

                    statusCell.removeClass("badge-warning-glow badge-success-glow badge-danger-glow badge-info-glow")
                              .addClass(badgeClass)
                              .html(badgeHtml);
                }

                if (data.status === "Success" || data.status === "Failed") {
                    if (selectedDeploymentIdForConsole === data.deploymentId) {
                        const statusText = data.status === "Success" ? "نجاح العملية" : "فشل العملية";
                        appendLogLine(`[النظام] انتهت عملية النشر للسيرفر: ${statusText}`, new Date().toISOString(), data.status === "Failed");
                    }
                }
            });
        } else {
            console.warn("SignalR client is not loaded. Falling back to HTTP Polling for logs.");
        }

        // آلية استرجاع السجلات عبر الـ Polling عند غياب SignalR
        let pollingIntervals = {};
        function startPolling(deploymentId, serverName) {
            if (pollingIntervals[deploymentId]) return;
            pollingIntervals[deploymentId] = setInterval(function() {
                $.getJSON(`/Dashboard/GetDeploymentLogs/${deploymentId}`, function(logs) {
                    let isCompleted = false;
                    let success = false;

                    if (selectedDeploymentIdForConsole === deploymentId) {
                        $("#terminalConsole").empty();
                    }

                    logs.forEach(function(log) {
                        if (selectedDeploymentIdForConsole === deploymentId) {
                            appendLogLine(log.message, log.timestamp, log.isError);
                        }
                        if (log.message.includes("successful deployment execution") || log.message.includes("[Success]")) {
                            isCompleted = true;
                            success = true;
                        }
                        if (log.message.includes("Agent reported failure") || log.message.includes("Error communicating with agent") || log.message.includes("[Error]")) {
                            isCompleted = true;
                            success = false;
                        }
                    });

                    if (isCompleted) {
                        clearInterval(pollingIntervals[deploymentId]);
                        delete pollingIntervals[deploymentId];

                        // تحديث الشارات مرئياً
                        const statusCell = $(`.status-badge-${deploymentId}`);
                        if (statusCell.length > 0) {
                            if (success) {
                                statusCell.removeClass("badge-info-glow badge-warning-glow").addClass("badge-success-glow").text("ناجح");
                            } else {
                                statusCell.removeClass("badge-info-glow badge-warning-glow").addClass("badge-danger-glow").text("فاشل");
                            }
                        }
                    }
                });
            }, 2000);
        }



        // تحديد كافة السيرفرات المستهدفة
        $("#selectAllServers").click(function() {
            const allChecked = $(".server-checkbox-input:checked").length === $(".server-checkbox-input").length;
            $(".server-checkbox-input").prop("checked", !allChecked);
        });

        // تشغيل عملية النشر
        $("#btnDeploy").click(function() {
            const serverIds = [];
            $(".server-checkbox-input:checked").each(function() {
                serverIds.push($(this).val());
            });

            if (serverIds.length === 0) {
                alert("يرجى تحديد خادم (سيرفر) واحد مستهدف على الأقل!");
                return;
            }

            const packageUrl = $("#packageUrl").val().trim();

            if (!packageUrl) {
                alert("يرجى ملء حقل رابط الحزمة البرمجية!");
                return;
            }

            $("#btnDeploy").prop("disabled", true).html('<span class="spinner-border spinner-border-sm me-2"></span> جاري تهيئة الاتصال...');

            $.ajax({
                url: '/Dashboard/Deploy',
                type: 'POST',
                traditional: true,
                data: {
                    serverIds: serverIds,
                    packageUrl: packageUrl
                },
                success: function(response) {
                    $("#btnDeploy").prop("disabled", false).html('<i class="bi bi-rocket-takeoff-fill me-2 fs-5"></i> تنفيذ النشر المتوازي');
                    
                    if (response.success) {
                        $("#activeRunPanel").removeClass("d-none");
                        $("#activeRunTableBody").empty();

                        response.deployments.forEach(function(dep, index) {
                            if (signalRAvailable && connection) {
                                // انضمام إلى مجموعة النشر الحالية في SignalR
                                connection.invoke("JoinDeploymentGroup", dep.deploymentId)
                                    .then(() => console.log(`Joined group for deployment: ${dep.deploymentId}`))
                                    .catch(err => console.error(err));
                            } else {
                                // تفعيل التحديث التلقائي الدوري (Polling)
                                startPolling(dep.deploymentId, dep.serverName);
                            }

                            const row = `
                                <tr>
                                    <td class="fw-semibold text-white">
                                        <div title="${dep.serverName}">${dep.iisSiteName}</div>
                                        <small class="text-secondary-light">${dep.serverName}</small>
                                    </td>
                                    <td>
                                        <span class="badge badge-info-glow px-2 py-1 fs-8 status-badge-${dep.deploymentId}">
                                            <span class="status-pulse-inprogress me-1"></span> جاري النشر
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-primary-gradient py-1 px-3 fs-8 view-console-btn" data-id="${dep.deploymentId}" data-site="${dep.iisSiteName}">
                                            <i class="bi bi-terminal"></i> عرض السجلات
                                        </button>
                                    </td>
                                </tr>
                            `;
                            $("#activeRunTableBody").append(row);

                            if (index === 0) {
                                selectDeploymentForConsole(dep.deploymentId, dep.iisSiteName);
                            }
                        });

                        $("#noHistoryRow").remove();
                        response.deployments.forEach(function(dep) {
                            const histRow = `
                                <tr class="bg-primary bg-opacity-10">
                                    <td class="fw-semibold text-white">
                                        <div title="${dep.serverName}">${dep.iisSiteName}</div>
                                        <small class="text-secondary-light">${dep.serverName}</small>
                                    </td>
                                    <td class="text-truncate text-secondary" style="max-width: 250px;"><a href="${packageUrl}" target="_blank" class="text-info text-decoration-none fs-7">${packageUrl}</a></td>
                                    <td class="text-secondary-light fs-7">${dep.startedAt}</td>
                                    <td><span class="badge badge-info-glow px-2 py-1 fs-8 status-badge-${dep.deploymentId}"><span class="status-pulse-inprogress me-1"></span> جاري النشر</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary py-1 px-3 fs-8 load-history-log" data-id="${dep.deploymentId}" data-site="${dep.iisSiteName}">
                                            <i class="bi bi-eye-fill"></i> عرض السجلات
                                        </button>
                                    </td>
                                </tr>
                            `;
                            $("#historyTableBody").prepend(histRow);
                        });
                    } else {
                        alert("فشل تشغيل عملية النشر: " + response.message);
                    }
                },
                error: function(err) {
                    $("#btnDeploy").prop("disabled", false).html('<i class="bi bi-rocket-takeoff-fill me-2 fs-5"></i> تنفيذ النشر المتوازي');
                    alert("حدث خطأ أثناء التواصل مع النظام.");
                }
            });
        });

        $(document).on("click", ".view-console-btn", function() {
            const id = $(this).data("id");
            const site = $(this).data("site");
            selectDeploymentForConsole(id, site);
        });

        $(document).on("click", ".load-history-log", function() {
            const id = $(this).data("id");
            const site = $(this).data("site");
            selectDeploymentForConsole(id, site, true); 
        });

        $("#btnClearConsole").click(function() {
            $("#terminalConsole").empty();
        });

        function selectDeploymentForConsole(deploymentId, siteName, fetchFromDb = false) {
            selectedDeploymentIdForConsole = deploymentId;
            $("#consoleHeader").text(`المراقب: بث حي لسجلات [${siteName}]`);
            $("#terminalConsole").empty().append(`<div class="terminal-line manager"><span class="terminal-timestamp">[النظام]</span>تم الاتصال بسجل الموقع [${siteName}] وننتظر البيانات...</div>`);

            if (fetchFromDb) {
                $("#consoleHeader").text(`المراقب: أرشيف سجلات [${siteName}]`);
                $.getJSON(`/Dashboard/GetDeploymentLogs/${deploymentId}`, function(logs) {
                    if (logs.length === 0) {
                        $("#terminalConsole").append(`<div class="terminal-line warning"><span class="terminal-timestamp">[النظام]</span>لا توجد سجلات محفوظة لهذه العملية.</div>`);
                    } else {
                        logs.forEach(function(log) {
                            appendLogLine(log.message, log.timestamp, log.isError);
                        });
                    }
                });
            }
        }

        function appendLogLine(message, timestamp, isError) {
            const timeFormatted = timestamp ? timestamp.split(" ").pop() : new Date().toLocaleTimeString();
            let logClass = "";
            if (isError) logClass = "error";
            else if (message.includes("[IIS Simulation]") || message.includes("[IIS]")) logClass = "warning";
            else if (message.includes("[Manager]") || message.includes("[النظام]")) logClass = "manager";

            const logElement = $(`<div class="terminal-line ${logClass}"><span class="terminal-timestamp">[${timeFormatted}]</span>${escapeHtml(message)}</div>`);
            $("#terminalConsole").append(logElement);
            
            const consoleElement = document.getElementById("terminalConsole");
            consoleElement.scrollTop = consoleElement.scrollHeight;
        }

        function updateMetric(elementId, increment) {
            const element = $(`#${elementId}`);
            if (element.length > 0) {
                const currentVal = parseInt(element.text()) || 0;
                element.text(currentVal + increment);
            }
        }

        function escapeHtml(text) {
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        // خاصية البحث في السيرفرات
        $("#serverSearch").on("input", function() {
            const searchTerm = $(this).val().toLowerCase().trim();
            $(".server-option-item").each(function() {
                const searchData = $(this).data("search") || "";
                if (searchData.includes(searchTerm)) {
                    $(this).removeClass("d-none");
                } else {
                    $(this).addClass("d-none");
                }
            });
        });
    });
</script>
}
