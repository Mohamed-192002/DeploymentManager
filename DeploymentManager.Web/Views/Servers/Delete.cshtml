@model DeploymentManager.Web.Models.Server

@{
    ViewData["Title"] = "حذف السيرفر";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card card-glass border-danger border-opacity-25 p-4 text-center">
            <div class="text-danger mb-3">
                <i class="bi bi-exclamation-triangle-fill" style="font-size: 3.5rem;"></i>
            </div>
            
            <h3 class="fw-bold text-white mb-2">هل تريد بالتأكيد حذف اتصال هذا السيرفر؟</h3>
            <p class="text-secondary-light fs-6 mb-4">
                هل أنت متأكد من رغبتك في حذف السيرفر <strong class="text-white">@Model.Name</strong>؟ 
                هذا الإجراء نهائي وسيقوم بحذف جميع السجلات التاريخية لعمليات النشر المرتبطة بهذا السيرفر من النظام.
            </p>

            <div class="bg-black bg-opacity-20 rounded p-3 mb-4 text-start border border-secondary border-opacity-10" dir="rtl">
                <div class="row g-2 fs-7 text-secondary-light">
                    <div class="col-5 text-start fw-semibold">عنوان الـ IP:</div>
                    <div class="col-7 text-white">@Model.IpAddress</div>
                    
                    <div class="col-5 text-start fw-semibold">موقع الـ IIS:</div>
                    <div class="col-7 text-white">@Model.IisSiteName</div>
                    
                    <div class="col-5 text-start fw-semibold">رابط الوكيل:</div>
                    <div class="col-7 text-info" dir="ltr">@Model.ApiBaseUrl</div>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-center gap-3">
                    <a asp-action="Index" class="btn btn-outline-secondary border-secondary border-opacity-25 px-4 py-2 text-secondary-light">
                        إلغاء
                    </a>
                    <button type="submit" class="btn btn-danger px-4 py-2 border-0" style="background-color: var(--color-danger)">
                        <i class="bi bi-trash-fill me-1"></i> تأكيد الحذف
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
