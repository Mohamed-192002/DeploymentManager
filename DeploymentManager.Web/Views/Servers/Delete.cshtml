@model DeploymentManager.Web.Models.Server

@{
    ViewData["Title"] = "Delete Server";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card card-glass border-danger border-opacity-25 p-4 text-center">
            <div class="text-danger mb-3">
                <i class="bi bi-exclamation-triangle-fill" style="font-size: 3.5rem;"></i>
            </div>
            
            <h3 class="fw-bold text-white mb-2">Delete Server Connection?</h3>
            <p class="text-secondary-light fs-6 mb-4">
                Are you sure you want to remove the server <strong class="text-white">@Model.Name</strong>? 
                This action is permanent and will delete all historical logs associated with this server target.
            </p>

            <div class="bg-black bg-opacity-20 rounded p-3 mb-4 text-start border border-secondary border-opacity-10">
                <div class="row g-2 fs-7 text-secondary-light">
                    <div class="col-5 text-end fw-semibold">IP Address:</div>
                    <div class="col-7 text-white">@Model.IpAddress</div>
                    
                    <div class="col-5 text-end fw-semibold">IIS Site Name:</div>
                    <div class="col-7 text-white">@Model.IisSiteName</div>
                    
                    <div class="col-5 text-end fw-semibold">Agent Endpoint:</div>
                    <div class="col-7 text-info">@Model.ApiBaseUrl</div>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-center gap-3">
                    <a asp-action="Index" class="btn btn-outline-secondary border-secondary border-opacity-25 px-4 py-2 text-secondary-light">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-danger px-4 py-2 border-0" style="background-color: var(--color-danger)">
                        <i class="bi bi-trash-fill me-1"></i> Confirm Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
