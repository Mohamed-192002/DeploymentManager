<!DOCTYPE html>
<html lang="ar" dir="rtl" data-bs-theme="dark" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - فيلوسيتي ديبلوى</title>
    
    <!-- Google Fonts: Cairo (Arabic) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Bootstrap RTL CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" integrity="sha384-dpuaG1suU0eT09tx5plTaGMLBsfDLzUCCUXOY2j/LSvXYuG6Bqs43ALlhIqAJVRb" crossorigin>
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    
    <!-- Custom site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column h-100 dark-theme">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-glass border-bottom border-secondary border-opacity-25 py-3 mb-4 sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2 fw-bold text-gradient" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-rocket-takeoff-fill fs-4 text-primary"></i>
                    <span>فيلوسيتي ديبلوى</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto gap-2">
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-pill d-flex align-items-center gap-2 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active bg-primary-subtle text-primary fw-medium" : "text-secondary-light")" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-grid-1x2-fill"></i> لوحة التحكم بالنشر
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-pill d-flex align-items-center gap-2 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Servers" ? "active bg-primary-subtle text-primary fw-medium" : "text-secondary-light")" asp-controller="Servers" asp-action="Index">
                                <i class="bi bi-hdd-network-fill"></i> السيرفرات المستهدفة
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container flex-shrink-0">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto py-3 border-top border-secondary border-opacity-10 bg-glass text-center text-secondary-light">
        <div class="container">
            <span class="fs-7">&copy; 2026 - فيلوسيتي ديبلوى - نظام إدارة ونشر التطبيقات v1.0.0</span>
        </div>
    </footer>

    <!-- JS dependencies -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <!-- Note: Bootstrap RTL uses the same bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin></script>
    
    <!-- SignalR JS Client via CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.24/signalr.min.js"></script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
